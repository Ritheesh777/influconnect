# ══════════════════════════════════════════════════════════
#  Collably — environment template
#
#  Copy this to `.env` and fill in real values:   cp .env.example .env
#
#  ⚠️  `.env` is gitignored and must NEVER be committed. This
#      example file holds placeholders only — no real secrets.
#      Production values are set in the Render dashboard
#      (Service → Environment), not from this file.
# ══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=5050
NODE_ENV=development
# Allowed browser origin (CORS + Socket.io). In production: your Vercel URL.
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────
# Local dev:
MONGO_URI=mongodb://127.0.0.1:27017/collably
# Production (MongoDB Atlas) — data persists across restarts/deploys:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/collably
#
# NOTE: when MONGO_URI points at a real cloud database, the container's
# embedded MongoDB is skipped automatically (see start.sh), and `npm run seed`
# refuses to wipe existing data unless you pass FORCE_SEED=1.

# ── Auth ──────────────────────────────────────────────────
# Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Cloudinary (image / file storage) ─────────────────────
# From cloudinary.com → Dashboard → Product Environment Credentials.
# If left blank, uploads fall back to inline data URIs (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Admin bootstrap (used by `npm run seed`) ──────────────
ADMIN_EMAIL=admin@collably.com
ADMIN_PASSWORD=Admin@12345
